{
  "name": "Sayso",
  "image": "mcr.microsoft.com/devcontainers/universal:5",
  "postCreateCommand": "curl -fsSL https://claude.ai/install.sh | bash && curl -fsSL https://sayso.me/install | sh",
  "postStartCommand": "nohup bash -c '~/.local/bin/sayso --port 3000 --no-open &' 2> /tmp/postStart.err.log 1> /tmp/postStart.out.log",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Sayso",
      "onAutoForward": "silent"
    }
  }
}
